{
  "name": "ecommerce-astro",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "node scripts/generate-specs.mjs && astro dev",
    "dev:cms": "tinacms dev -c \"astro dev\"",
    "build": "node scripts/generate-specs.mjs && tinacms build && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "generate:options": "node scripts/generate-tina-options.mjs",
    "fix:refs": "node scripts/fix-tina-refs.mjs",
    "fix:refs:watch": "node scripts/fix-tina-refs-watch.mjs",
    "lint": "astro check",
    "clean": "rm -rf dist .astro node_modules/.vite",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "^5.0.5",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vercel": "^10.0.7",
    "@nanostores/persistent": "^1.3.3",
    "@nanostores/react": "^1.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.3",
    "autoprefixer": "^10.4.27",
    "gray-matter": "^4.0.3",
    "nanostores": "^1.3.0",
    "postcss": "^8.5.9",
    "puppeteer": "^24.42.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwindcss": "^3.4.19",
    "tinacms": "^3.7.2"
  },
  "devDependencies": {
    "@tinacms/cli": "^2.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.1",
    "husky": "^9.1.7"
  },
  "overrides": {
    "esbuild": "0.20.2"
  }
}
