---
// src/layouts/BaseLayout.astro
import SEOHead from "../components/layout/SEOHead.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: "website" | "product";
}

const { title, description, image, type } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <SEOHead {title} {description} {image} {type} />
  </head>
  <body class="flex flex-col min-h-dvh bg-[var(--color-bg)]">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
