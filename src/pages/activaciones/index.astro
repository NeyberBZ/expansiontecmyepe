---
// src/pages/activaciones/index.astro
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BreadCrumb from "../../components/ui/BreadCrumb.astro";
import Badge from "../../components/ui/Badge.astro";

const activations = await getCollection(
  "activations",
  (a: any) => a.data.isPublished,
);

// 1. Resolvemos las localizaciones antes de renderizar el HTML
const activationsWithData = await Promise.all(
  activations.map(async (act: any) => {
    // CORRECCIÓN: Especificar la colección 'locations' y pasar el ID string
    const loc = act.data.location
      ? await getEntry("locations", act.data.location)
      : null;
    return {
      ...act,
      locationName: loc?.data.name ?? "Ubicación no especificada",
    };
  }),
);

const sorted = activationsWithData.sort(
  (a: any, b: any) =>
    new Date(a.data.startDate).getTime() - new Date(b.data.startDate).getTime(),
);

const now = new Date();
const upcoming = sorted.filter((a: any) => new Date(a.data.endDate) >= now);
const past = sorted.filter((a: any) => new Date(a.data.endDate) < now);
---

<BaseLayout
  title="Activaciones"
  description="Eventos, promociones y activaciones en nuestras sucursales ExpansionTec Lima."
>
  <div style="max-width:1200px;margin:0 auto;padding:2rem 1rem;">
    <BreadCrumb
      crumbs={[{ label: "Inicio", href: "/" }, { label: "Activaciones" }]}
    />

    <h1
      style="font-family:var(--font-display);font-size:clamp(1.5rem,1.2rem+1.25vw,2.25rem);font-weight:700;color:var(--color-text);margin-bottom:0.5rem;"
    >
      Activaciones
    </h1>
    <p style="color:var(--color-text-muted);margin-bottom:2rem;">
      Eventos y promociones especiales en nuestras tiendas
    </p>

    {
      upcoming.length > 0 && (
        <section style="margin-bottom:3rem;">
          <h2 style="font-size:1rem;font-weight:700;color:var(--color-text);margin-bottom:1rem;display:flex;align-items:center;gap:8px;">
            <span style="width:8px;height:8px;border-radius:50%;background:var(--color-success);display:inline-block;" />
            Próximas y activas
          </h2>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(min(300px,100%),1fr));gap:1rem;">
            {upcoming.map((act) => {
              const startDate = new Date(act.data.startDate);
              const endDate = new Date(act.data.endDate);
              const isActive = startDate < now;
              const startStr = startDate.toLocaleDateString("es-PE");
              const endStr = endDate.toLocaleDateString("es-PE");
              return (
                <a
                  href={`/activaciones/${act.slug}`}
                  style="text-decoration:none;"
                >
                  <article style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:12px;overflow:hidden;transition:box-shadow 180ms ease,transform 180ms ease;">
                    {act.data.banner && (
                      <div style="aspect-ratio:16/7;overflow:hidden;background:var(--color-surface-offset);">
                        <img
                          src={act.data.banner}
                          alt={act.data.title}
                          loading="lazy"
                          style="width:100%;height:100%;object-fit:cover;"
                        />
                      </div>
                    )}
                    <div style="padding:1.25rem;">
                      <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;">
                        <h3 style="font-weight:700;font-size:0.95rem;color:var(--color-text);line-height:1.3;">
                          {act.data.title}
                        </h3>
                        <Badge variant={isActive ? "success" : "primary"}>
                          {isActive ? "Activa" : "Próxima"}
                        </Badge>
                      </div>
                      <p style="font-size:0.8rem;color:var(--color-text-muted);margin-bottom:6px;">
                        📍 {act.locationName}
                      </p>
                      <p style="font-size:0.8rem;color:var(--color-text-faint);">
                        {startStr} → {endStr}
                      </p>
                    </div>
                  </article>
                </a>
              );
            })}
          </div>
        </section>
      )
    }

    {
      past.length > 0 && (
        <section>
          <h2 style="font-size:1rem;font-weight:700;color:var(--color-text-muted);margin-bottom:1rem;display:flex;align-items:center;gap:8px;">
            <span style="width:8px;height:8px;border-radius:50%;background:var(--color-text-faint);display:inline-block;" />
            Anteriores
          </h2>
          <div style="display:flex;flex-direction:column;gap:8px;">
            {past.map((act) => {
              const endStr = new Date(act.data.endDate).toLocaleDateString(
                "es-PE",
              );
              return (
                <a
                  href={`/activaciones/${act.slug}`}
                  style="text-decoration:none;"
                >
                  <div style="padding:12px 16px;background:var(--color-surface);border:1px solid var(--color-border);border-radius:8px;display:flex;justify-content:space-between;align-items:center;opacity:0.7;">
                    <div>
                      <span style="font-size:0.875rem;font-weight:600;color:var(--color-text);">
                        {act.data.title}
                      </span>
                      <p style="font-size:0.75rem;color:var(--color-text-muted);">
                        📍 {act.locationName}
                      </p>
                    </div>
                    <span style="font-size:0.75rem;color:var(--color-text-faint);white-space:nowrap;">
                      {endStr}
                    </span>
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      )
    }
  </div>
</BaseLayout>
