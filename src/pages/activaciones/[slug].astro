---
// src/pages/activaciones/[slug].astro
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BreadCrumb from "../../components/ui/BreadCrumb.astro";
import Badge from "../../components/ui/Badge.astro";
import Icon from "../../components/ui/Icon.astro";

export async function getStaticPaths() {
  const activations = await getCollection("activations");
  return activations.map((a: any) => ({
    params: { slug: a.slug || a.id.replace(/\.[^/.]+$/, "") },
  }));
}

const { slug } = Astro.params;
const activation = await getEntry("activations", slug!);
if (!activation) return Astro.redirect("/activaciones");

const { Content } = await activation.render();

// 1. Resolución de localizaciones (Múltiples sedes)
const locationEntries = await Promise.all(
  (activation.data.locations || []).map((id: string) =>
    getEntry("locations", id),
  ),
);
const validLocations = locationEntries.filter((l) => l !== undefined);

// 2. Lógica de tiempo blindada (Pre-calculada)
const nowTime = Date.now();
const startTime = new Date(activation.data.startDate).getTime();
const endTime = new Date(activation.data.endDate).getTime();

const isActive = nowTime >= startTime && nowTime <= endTime;
const isUpcoming = nowTime < startTime;

// 3. Formateo de fechas
const formatDate = (date: Date) =>
  date.toLocaleDateString("es-PE", {
    weekday: "long",
    year: "numeric",
    month: "long",
    day: "numeric",
  });

const startDisplay = formatDate(new Date(activation.data.startDate));
const endDisplay = formatDate(new Date(activation.data.endDate));
---

<BaseLayout
  title={activation.data.title}
  description={`${activation.data.title}. Evento disponible en ExpansionTec del ${startDisplay} al ${endDisplay}.`}
  image={activation.data.banner}
>
  <div class="w-full mt-20"></div>

  <article class="container mx-auto px-4 py-8 md:py-12 max-w-4xl">
    <BreadCrumb
      crumbs={[
        { label: "Inicio", href: "/" },
        { label: "Activaciones", href: "/activaciones" },
        { label: activation.data.title },
      ]}
    />

    {/* Banner Hero */}
    {
      activation.data.banner && (
        <div class="relative aspect-[21/9] md:aspect-[16/6] rounded-3xl overflow-hidden mt-8 mb-10 shadow-2xl shadow-orange-500/10">
          <img
            src={activation.data.banner}
            alt={activation.data.title}
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>
      )
    }

    <div class="flex flex-col gap-6">
      {/* Estado y Ubicaciones */}
      <div class="flex flex-wrap items-center gap-4">
        <Badge
          variant={isActive ? "success" : isUpcoming ? "primary" : "neutral"}
        >
          {
            isActive
              ? "Activa ahora"
              : isUpcoming
                ? "Próximamente"
                : "Evento finalizado"
          }
        </Badge>

        <div class="flex flex-wrap gap-3">
          {
            validLocations.map((loc) => (
              <a
                href={`/sucursales/${loc.id || loc.slug}`}
                class="flex items-center gap-1.5 text-sm font-bold text-orange-600 hover:text-orange-700 transition-colors bg-orange-50 px-3 py-1.5 rounded-full"
              >
                <Icon id="icon-location" name="location" class="w-4 h-4" />
                {loc.data.name}
              </a>
            ))
          }
        </div>
      </div>

      <h1
        class="font-satoshi text-3xl md:text-5xl font-bold text-gray-900 leading-tight"
      >
        {activation.data.title}
      </h1>

      {/* Info Card de Fechas */}
      <div
        class="grid grid-cols-1 md:grid-cols-2 gap-4 p-6 bg-gray-50 border border-gray-100 rounded-3xl"
      >
        <div class="space-y-1">
          <p
            class="text-[10px] font-black uppercase tracking-widest text-gray-400"
          >
            Inicia
          </p>
          <p class="text-gray-900 font-bold capitalize">{startDisplay}</p>
        </div>
        <div
          class="space-y-1 border-t md:border-t-0 md:border-l border-gray-200 pt-4 md:pt-0 md:pl-6"
        >
          <p
            class="text-[10px] font-black uppercase tracking-widest text-gray-400"
          >
            Finaliza
          </p>
          <p class="text-gray-900 font-bold capitalize">{endDisplay}</p>
        </div>
      </div>

      {/* Contenido Markdown */}
      <div
        class="prose prose-orange prose-lg max-w-none mt-4
        prose-headings:font-satoshi prose-headings:font-bold prose-headings:text-gray-900
        prose-p:text-gray-600 prose-p:leading-relaxed
        prose-li:text-gray-600 prose-strong:text-gray-900"
      >
        <Content />
      </div>

      {/* Botón de Retorno */}
      <div class="pt-10 border-t border-gray-100 mt-10">
        <a
          href="/activaciones"
          class="inline-flex items-center gap-2 text-gray-500 hover:text-orange-600 font-bold transition-colors"
        >
          <Icon name="arrow-left" class="w-5 h-5" />
          Volver a todas las activaciones
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
