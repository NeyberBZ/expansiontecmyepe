---
// src/pages/sucursales/index.astro
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BreadCrumb from "../../components/ui/BreadCrumb.astro";
import Badge from "../../components/ui/Badge.astro";

const locations = await getCollection("locations");
const active = locations.filter((l: any) => l.data.isActive);
---

<BaseLayout
  title="Sucursales"
  description="Encuentra nuestras tiendas en Lima. Visítanos y conoce nuestros productos."
>
  <div style="max-width:1200px;margin:0 auto;padding:2rem 1rem;">
    <BreadCrumb
      crumbs={[{ label: "Inicio", href: "/" }, { label: "Sucursales" }]}
    />

    <h1
      style="font-family:var(--font-display);font-size:clamp(1.5rem,1.2rem+1.25vw,2.25rem);font-weight:700;color:var(--color-text);margin-bottom:0.5rem;"
    >
      Nuestras Sucursales
    </h1>
    <p style="color:var(--color-text-muted);margin-bottom:2rem;">
      {active.length} tiendas en Lima
    </p>

    <div
      style="display:grid;grid-template-columns:repeat(auto-fill,minmax(min(320px,100%),1fr));gap:1.5rem;"
    >
      {
        active.map((loc: any) => (
          <a href={`/sucursales/${loc.slug}`} style="text-decoration:none;">
            <article
              style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:12px;padding:1.5rem;transition:box-shadow 180ms ease,transform 180ms ease;"
              onmouseover="this.style.boxShadow='0 8px 24px oklch(0.2 0.01 80/0.12)';this.style.transform='translateY(-2px)'"
              onmouseout="this.style.boxShadow='none';this.style.transform='none'"
            >
              <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1rem;">
                <h2 style="font-family:var(--font-display);font-size:1.1rem;font-weight:700;color:var(--color-text);">
                  {loc.data.name}
                </h2>
                <Badge variant="primary">{loc.data.district}</Badge>
              </div>

              <div style="display:flex;flex-direction:column;gap:8px;">
                <div style="display:flex;gap:10px;align-items:flex-start;">
                  <span style="color:var(--color-primary);flex-shrink:0;">
                    📍
                  </span>
                  <span style="font-size:0.875rem;color:var(--color-text-muted);">
                    {loc.data.address}
                  </span>
                </div>
                <div style="display:flex;gap:10px;align-items:center;">
                  <span style="color:var(--color-primary);flex-shrink:0;">
                    📞
                  </span>
                  <span style="font-size:0.875rem;color:var(--color-text-muted);">
                    {loc.data.phone}
                  </span>
                </div>
                <div style="display:flex;gap:10px;align-items:center;">
                  <span style="color:var(--color-primary);flex-shrink:0;">
                    🕐
                  </span>
                  <span style="font-size:0.875rem;color:var(--color-text-muted);">
                    {loc.data.schedule}
                  </span>
                </div>
              </div>

              <div style="margin-top:1.25rem;padding-top:1rem;border-top:1px solid var(--color-divider);">
                <span style="font-size:0.8rem;color:var(--color-primary);font-weight:600;">
                  Ver detalles →
                </span>
              </div>
            </article>
          </a>
        ))
      }
    </div>
  </div>
</BaseLayout>
