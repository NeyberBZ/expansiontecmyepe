---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Inicio"
  description="Tecnología y periféricos gaming en Lima. Encuentra los mejores productos en nuestras sucursales."
>
  <section class="mx-auto max-w-wide px-4 py-20 text-center">
    <h1 class="font-display text-2xl font-bold text-[var(--color-text)] mb-4">
      Bienvenido a ExpansionTec
    </h1>
    <p class="text-[var(--color-text-muted)] max-w-narrow mx-auto">
      Periféricos gaming y tecnología al mejor precio en Lima.
    </p>
    <a
      href="/tienda"
      class="inline-block mt-8 px-6 py-3 bg-[var(--color-primary)] text-[var(--color-text-inverse)] rounded-lg text-sm font-medium hover:bg-[var(--color-primary-hover)] transition-colors"
    >
      Ver tienda →
    </a>
  </section>
</BaseLayout>
