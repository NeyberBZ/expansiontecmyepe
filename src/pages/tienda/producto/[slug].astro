---
// src/pages/tienda/producto/[slug].astro
import client from "../../../../tina/__generated__/client";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const productsResponse = await client.queries.productsConnection();
  const products = productsResponse.data.productsConnection.edges;

  return (products || []).map((edge) => ({
    params: { slug: edge?.node?._sys?.filename },
  })).filter((item) => item.params.slug);
}

const { slug } = Astro.params;

const tinaData = await client.queries.products({
  relativePath: `${slug}.md`,
});

const producto = tinaData?.data?.products;

const safeTitle = producto.title
  .toLowerCase()
  .replace(/\//g, "-")
  .replace(/[^a-z0-9]/gi, "-")
  .replace(/-+/g, "-")
  .replace(/^-|-$/g, "");

const pdfUrl = `/specs/${safeTitle}.pdf`;

const discount = producto.salePrice
  ? Math.round((1 - producto.salePrice / producto.price) * 100)
  : null;
---

<BaseLayout
  title={producto.seoTitle ?? producto.title}
  description={producto.seoDescription ??
    `Compra ${producto.title} en ExpansionTec Lima.`}
  image={producto.images?.[0] || ""}
  type="product"
>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Product",
      name: producto.title,
      image: producto.images,
      offers: {
        "@type": "Offer",
        price: producto.salePrice ?? producto.price,
        priceCurrency: "PEN",
        availability: producto.inStock
          ? "https://schema.org/InStock"
          : "https://schema.org/OutOfStock",
      },
    })}
  />

  <div class="w-full mx-auto">
    <div class="w-full h-23"></div>

    <div class="z-40 w-full bg-orange-100 shadow-sm overflow-x-auto">
      <div
        class="max-w-350 mx-auto px-4 h-20 flex items-center justify-between gap-8 whitespace-nowrap"
      >
        <div class="flex items-center gap-4">
          <h1
            class="text-2xl font-body font-medium text-gray-900 uppercase tracking-tight"
          >
            {producto.title}
          </h1>

          {
            discount && (
              <span class="bg-red-600 text-white px-3 py-1 rounded-full text-xs font-black">
                -{discount}% OFF
              </span>
            )
          }
        </div>

        <nav class="hidden md:flex items-center gap-10">
          <button
            data-tab-target="general"
            class="tab-btn font-bold text-gray-500 hover:text-gray-900 transition-colors active-tab"
          >
            General
          </button>

          <button
            data-tab-target="specs"
            class="tab-btn font-bold text-gray-500 hover:text-gray-900 transition-colors"
          >
            Especificaciones
          </button>

          {
            producto.specs && producto.specs.length > 0 && (
              <a
                href={pdfUrl}
                download
                class="flex items-center gap-2 text-orange-600 font-bold hover:text-orange-700 transition-colors"
              >
                Ficha Técnica
              </a>
            )
          }
        </nav>

        <div class="flex items-center gap-6">
          <div class="flex flex-col items-end">
            {
              producto.salePrice && (
                <span class="text-xs text-gray-400 line-through">
                  S/ {producto.price}
                </span>
              )
            }
            <span class="text-2xl font-black text-gray-900 leading-none">
              S/ {producto.salePrice || producto.price}
            </span>
          </div>

          <button
            class="bg-[#0f172a] text-white px-8 py-3 rounded-full font-bold text-sm hover:bg-slate-800 transition-all"
          >
            Comprar ahora
          </button>
        </div>
      </div>
    </div>

    <div class="max-w-300 mx-auto px-4 py-12">
      <div id="general" class="tab-content block">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-20">
          <div id="product-images">
            <img
              src={producto.images?.[0]}
              alt={producto.title}
              class="rounded-3xl shadow-xl w-full"
            />
          </div>

          <div class="prose prose-lg max-w-none">
            <h2 class="text-2xl font-bold mb-4 font-satoshi uppercase">
              Descripción
            </h2>

            <div>
              {producto.shortDescription}
            </div>
          </div>
        </div>
      </div>

      <div
        id="specs"
        class="tab-content hidden animate-in fade-in duration-500"
      >
        <h2 class="text-2xl font-bold mb-8 font-satoshi uppercase">
          Especificaciones Técnicas
        </h2>

        <div
          class="bg-white border border-gray-100 rounded-3xl overflow-hidden shadow-sm"
        >
          {
            producto.specs?.map((spec, i) => spec && (
              <div
                class={`grid grid-cols-1 md:grid-cols-3 p-6 ${i % 2 === 0 ? "bg-white" : "bg-gray-50"}`}
              >
                <span class="text-sm font-bold text-gray-400 uppercase tracking-widest">
                  {spec.key}
                </span>
                <span class="md:col-span-2 text-gray-900 font-medium">
                  {spec.value}
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <script>
    const tabBtns = document.querySelectorAll(".tab-btn");
    const tabContents = document.querySelectorAll(".tab-content");

    tabBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const target = btn.getAttribute("data-tab-target");
        tabBtns.forEach((b) => b.classList.remove("active-tab"));
        btn.classList.add("active-tab");

        tabContents.forEach((content) => {
          if (content.id === target) {
            content.classList.remove("hidden");
            content.classList.add("block");
          } else {
            content.classList.add("hidden");
            content.classList.remove("block");
          }
        });
      });
    });
  </script>
</BaseLayout>
