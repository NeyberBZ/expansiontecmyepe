---
// src/pages/tienda/[slug].astro
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BreadCrumb from "../../../components/ui/BreadCrumb.astro";
import Badge from "../../../components/ui/Badge.astro";
import AddToCart from "../../../components/shop/AddToCart.tsx";
// Eliminamos el duplicado de import { Content } ya que se obtiene de product.render()

export async function getStaticPaths() {
  const products = await getCollection("products");
  return products.map((p: any) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const product = await getEntry("products", slug!);
if (!product) return Astro.redirect("/tienda");

const { Content } = await product.render();

// ✅ SINCRONIZACIÓN: Usamos la misma lógica de limpieza que en el script de Node.js
// Esto elimina diagonales y caracteres especiales para que el link no se rompa
const safeTitle = product.data.title
  .toLowerCase()
  .replace(/\//g, '-')   // Reemplaza "/" por "-"
  .replace(/[^a-z0-9]/gi, '-') // Quita todo lo que no sea letra/número
  .replace(/-+/g, '-')   // Evita guiones dobles "--"
  .replace(/^-|-$/g, ''); // Quita guiones al inicio o final

const pdfUrl = `/specs/${safeTitle}.pdf`;

// ✅ brand y category (simplificado)
const brand = product.data.brand
  ? await getEntry("brands", product.data.brand)
  : undefined;
const category = product.data.category
  ? await getEntry("categories", product.data.category)
  : undefined;

// Resolver locations
const resolvedLocations = await Promise.all(
  (product.data.locations || []).map(async (loc: any) => {
    const locationId = loc.location;
    if (!locationId) return null;
    const location = await getEntry("locations", locationId).catch(() => null);
    return location;
  }),
);

const discount = product.data.salePrice
  ? Math.round((1 - product.data.salePrice / product.data.price) * 100)
  : null;
---

<BaseLayout
  title={product.data.seoTitle ?? product.data.title}
  description={product.data.seoDescription ??
    `Compra ${product.data.title} en ExpansionTec Lima.`}
  image={product.data.images[0]}
  type="product"
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Product",
      name: product.data.title,
      image: product.data.images,
      offers: {
        "@type": "Offer",
        price: product.data.salePrice ?? product.data.price,
        priceCurrency: "PEN",
        availability: product.data.inStock
          ? "https://schema.org/InStock"
          : "https://schema.org/OutOfStock",
      },
    })}
  />

  <div class="w-full mx-auto">
    <div class="w-full h-14"></div>

    <div
      class="sticky top-0 z-40 w-full bg-[#fdf2e3] border-b border-gray-100 shadow-sm overflow-x-auto"
    >
      <div
        class="max-w-[1400px] mx-auto px-4 h-20 flex items-center justify-between gap-8 whitespace-nowrap"
      >
        <div class="flex items-center gap-4">
          <h1
            class="text-2xl font-black text-gray-900 font-satoshi uppercase tracking-tight"
          >
            {product.data.title}
          </h1>
          {
            discount && (
              <span class="bg-orange-600 text-white px-3 py-1 rounded-full text-xs font-black">
                -{discount}% OFF
              </span>
            )
          }
        </div>

        <nav class="hidden md:flex items-center gap-10">
          <button
            data-tab-target="general"
            class="tab-btn font-bold text-gray-500 hover:text-gray-900 transition-colors active-tab"
          >
            General
          </button>
          <button
            data-tab-target="specs"
            class="tab-btn font-bold text-gray-500 hover:text-gray-900 transition-colors"
          >
            Especificaciones
          </button>

          {/* ✅ Botón de descarga condicional: Solo aparece si hay especificaciones */}
          {product.data.specs && product.data.specs.length > 0 && (
            <a
              href={pdfUrl}
              download
              class="flex items-center gap-2 text-orange-600 font-bold hover:text-orange-700 transition-colors"
            >
              Ficha Técnica
            </a>
          )}
        </nav>

        <div class="flex items-center gap-6">
          <div class="flex flex-col items-end">
            {
              product.data.salePrice && (
                <span class="text-xs text-gray-400 line-through">
                  S/ {product.data.price}
                </span>
              )
            }
            <span class="text-2xl font-black text-gray-900 leading-none">
              S/ {product.data.salePrice || product.data.price}
            </span>
          </div>
          <button
            class="bg-[#0f172a] text-white px-8 py-3 rounded-full font-bold text-sm hover:bg-slate-800 transition-all"
          >
            Comprar ahora
          </button>
        </div>
      </div>
    </div>

    <div class="max-w-[1200px] mx-auto px-4 py-12">
      <div id="general" class="tab-content block">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-20">
          <div id="product-images">
             {/* Aquí iría tu lógica de imágenes */}
             <img src={product.data.images[0]} alt={product.data.title} class="rounded-3xl shadow-xl w-full" />
          </div>

          <div class="prose prose-lg max-w-none">
            <h2 class="text-2xl font-bold mb-4 font-satoshi uppercase">Descripción</h2>
            <Content />
          </div>
        </div>
      </div>

      <div
        id="specs"
        class="tab-content hidden animate-in fade-in duration-500"
      >
        <h2 class="text-2xl font-bold mb-8 font-satoshi uppercase">Especificaciones Técnicas</h2>
        <div
          class="bg-white border border-gray-100 rounded-3xl overflow-hidden shadow-sm"
        >
          {
            product.data.specs?.map((spec: any, i: number) => (
              <div
                class={`grid grid-cols-1 md:grid-cols-3 p-6 ${i % 2 === 0 ? "bg-white" : "bg-gray-50"}`}
              >
                <span class="text-sm font-bold text-gray-400 uppercase tracking-widest">
                  {spec.key}
                </span>
                <span class="md:col-span-2 text-gray-900 font-medium">
                  {spec.value}
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <style>
    .active-tab {
      @apply text-[#ff4f00] relative;
    }
    .active-tab::after {
      content: "";
      @apply absolute -bottom-7 left-0 w-full h-[3px] bg-[#ff4f00] rounded-full;
    }
  </style>

  <script>
    const tabBtns = document.querySelectorAll(".tab-btn");
    const tabContents = document.querySelectorAll(".tab-content");

    tabBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const target = btn.getAttribute("data-tab-target");
        tabBtns.forEach((b) => b.classList.remove("active-tab"));
        btn.classList.add("active-tab");

        tabContents.forEach((content) => {
          if (content.id === target) {
            content.classList.remove("hidden");
            content.classList.add("block");
          } else {
            content.classList.add("hidden");
            content.classList.remove("block");
          }
        });
      });
    });
  </script>
</BaseLayout>