---
// src/pages/tienda/[slug].astro
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BreadCrumb from "../../components/ui/BreadCrumb.astro";
import Badge from "../../components/ui/Badge.astro";
import AddToCart from "../../components/shop/AddToCart.tsx";

export async function getStaticPaths() {
  const products = await getCollection("products");
  return products.map((p: any) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const product = await getEntry("products", slug!);
if (!product) return Astro.redirect("/tienda");

const { Content } = await product.render();

// ✅ Simplificado: brand y category ahora son strings directos
const brand = product.data.brand
  ? await getEntry("brands", product.data.brand)
  : undefined;
const category = product.data.category
  ? await getEntry("categories", product.data.category)
  : undefined;

// Resolver locations
const resolvedLocations = await Promise.all(
  (product.data.locations || []).map(async (loc: any) => {
    const locationId = loc.location;
    if (!locationId) return null;
    const location = await getEntry("locations", locationId).catch(() => null);
    return location;
  }),
);

const discount = product.data.salePrice
  ? Math.round((1 - product.data.salePrice / product.data.price) * 100)
  : null;
---

<BaseLayout
  title={product.data.seoTitle ?? product.data.title}
  description={product.data.seoDescription ??
    `Compra ${product.data.title} en ExpansionTec Lima.`}
  image={product.data.images[0]}
  type="product"
>
  <!-- JSON-LD Product -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Product",
      name: product.data.title,
      image: product.data.images,
      offers: {
        "@type": "Offer",
        price: product.data.salePrice ?? product.data.price,
        priceCurrency: "PEN",
        availability: product.data.inStock
          ? "https://schema.org/InStock"
          : "https://schema.org/OutOfStock",
      },
    })}
  />

  <div style="max-width:1200px;margin:0 auto;padding:2rem 1rem;">
    <BreadCrumb
      crumbs={[
        { label: "Inicio", href: "/" },
        { label: "Tienda", href: "/tienda" },
        { label: product.data.title },
      ]}
    />

    <div
      style="display:grid;grid-template-columns:1fr;gap:2rem;"
      id="product-layout"
    >
      <!-- Galería de imágenes -->
      <div id="product-images">
        <!-- Imagen principal -->
        <div
          style="aspect-ratio:4/3;background:var(--color-surface-offset);border-radius:12px;overflow:hidden;margin-bottom:0.75rem;"
        >
          {
            product.data.images[0] ? (
              <img
                id="main-image"
                src={product.data.images[0]}
                alt={product.data.title}
                width="800"
                height="600"
                loading="eager"
                fetchpriority="high"
                style="width:100%;height:100%;object-fit:cover;"
              />
            ) : (
              <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:4rem;">
                📦
              </div>
            )
          }
        </div>

        <!-- Thumbnails -->
        {
          product.data.images.length > 1 && (
            <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
              {product.data.images.map((img: any, i: any) => (
                <button
                  onclick={`document.getElementById('main-image').src='${img}'`}
                  style="width:72px;height:72px;border-radius:8px;overflow:hidden;border:2px solid var(--color-border);padding:0;cursor:pointer;background:var(--color-surface-offset);"
                >
                  <img
                    src={img}
                    alt={`Vista ${i + 1}`}
                    width="72"
                    height="72"
                    loading="lazy"
                    style="width:100%;height:100%;object-fit:cover;"
                  />
                </button>
              ))}
            </div>
          )
        }
      </div>

      <!-- Info del producto -->
      <div id="product-info">
        <!-- Badges -->
        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:1rem;">
          {product.data.featured && <Badge variant="primary">Destacado</Badge>}
          {discount && <Badge variant="error">-{discount}%</Badge>}
          {!product.data.inStock && <Badge variant="default">Sin stock</Badge>}
        </div>

        <!-- Marca y categoría -->
        <p
          style="font-size:0.875rem;color:var(--color-text-muted);margin-bottom:0.5rem;"
        >
          {brand?.data?.name || product.data.brand} · {
            category?.data?.name || product.data.category
          }
        </p>

        <!-- Título -->
        <h1
          style="font-family:var(--font-display);font-size:clamp(1.5rem,1.2rem + 1.25vw,2.25rem);font-weight:700;color:var(--color-text);margin-bottom:1rem;line-height:1.2;"
        >
          {product.data.title}
        </h1>

        <!-- Precio -->
        <div
          style="display:flex;align-items:center;gap:12px;margin-bottom:1.5rem;"
        >
          {
            product.data.salePrice ? (
              <>
                <span style="font-size:1.75rem;font-weight:800;color:var(--color-primary);">
                  S/ {product.data.salePrice.toLocaleString("es-PE")}
                </span>
                <span style="font-size:1.1rem;color:var(--color-text-faint);text-decoration:line-through;">
                  S/ {product.data.price.toLocaleString("es-PE")}
                </span>
              </>
            ) : (
              <span style="font-size:1.75rem;font-weight:800;color:var(--color-text);">
                S/ {product.data.price.toLocaleString("es-PE")}
              </span>
            )
          }
        </div>

        <!-- Disponibilidad -->
        <div
          style="display:flex;align-items:center;gap:8px;margin-bottom:1.5rem;"
        >
          <span
            style={`width:8px;height:8px;border-radius:50%;background:${product.data.inStock ? "var(--color-success)" : "var(--color-error)"};display:inline-block;`}
          ></span>
          <span style="font-size:0.875rem;color:var(--color-text-muted);">
            {product.data.inStock ? "En stock" : "Sin stock"}
          </span>
        </div>

        <AddToCart
          client:load
          product={{
            slug: product.slug,
            title: product.data.title,
            price: product.data.salePrice || product.data.price,
            image: product.data.images[0],
            brand: brand?.data?.name || product.data.brand,
            inStock: product.data.inStock,
          }}
        />

        <!-- Sucursales -->
        {
          resolvedLocations.length > 0 && (
            <div style="margin-top:1.5rem;padding:1rem;background:var(--color-surface);border:1px solid var(--color-border);border-radius:10px;">
              <p style="font-size:0.8rem;font-weight:600;color:var(--color-text-muted);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.05em;">
                Disponible en
              </p>
              <div style="display:flex;flex-wrap:wrap;gap:8px;">
                {resolvedLocations.filter(Boolean).map((loc: any) => (
                  <a
                    href={`/sucursales/${loc.slug}`}
                    style="font-size:0.8rem;padding:4px 10px;border-radius:999px;background:var(--color-primary-highlight);color:var(--color-primary);text-decoration:none;"
                  >
                    {loc.data?.name || loc.slug}
                  </a>
                ))}
              </div>
            </div>
          )
        }

        <!-- Tags -->
        {
          product.data.tags?.length > 0 && (
            <div style="margin-top:1rem;display:flex;flex-wrap:wrap;gap:6px;">
              {product.data.tags.map((tag: string) => (
                <span style="font-size:0.75rem;padding:3px 10px;border-radius:999px;background:var(--color-surface-offset);color:var(--color-text-muted);">
                  #{tag}
                </span>
              ))}
            </div>
          )
        }
      </div>
    </div>

    <!-- Especificaciones técnicas -->
    {
      product.data.specs?.length > 0 && (
        <div style="margin-top:3rem;">
          <h2 style="font-family:var(--font-display);font-size:1.25rem;font-weight:700;color:var(--color-text);margin-bottom:1rem;">
            Especificaciones técnicas
          </h2>
          <div style="border:1px solid var(--color-border);border-radius:10px;overflow:hidden;">
            {product.data.specs.map((spec: any, i: number) => (
              <div
                style={`display:grid;grid-template-columns:1fr 2fr;padding:12px 16px;${i % 2 === 0 ? "background:var(--color-surface);" : "background:var(--color-surface-2);"}`}
              >
                <span style="font-size:0.875rem;font-weight:600;color:var(--color-text-muted);">
                  {spec.key}
                </span>
                <span style="font-size:0.875rem;color:var(--color-text);">
                  {spec.value}
                </span>
              </div>
            ))}
          </div>
        </div>
      )
    }

    <!-- Descripción (contenido Markdown) -->
    <div style="margin-top:3rem;max-width:720px;">
      <h2
        style="font-family:var(--font-display);font-size:1.25rem;font-weight:700;color:var(--color-text);margin-bottom:1rem;"
      >
        Descripción
      </h2>
      <div
        style="color:var(--color-text);line-height:1.8;font-size:0.95rem;"
        class="prose"
      >
        <Content />
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  // Layout de 2 columnas en desktop
  function handleResize() {
    const layout = document.getElementById("product-layout");
    if (!layout) return;
    if (window.innerWidth >= 768) {
      layout.style.gridTemplateColumns = "1fr 1fr";
    } else {
      layout.style.gridTemplateColumns = "1fr";
    }
  }
  handleResize();
  window.addEventListener("resize", handleResize);
</script>
