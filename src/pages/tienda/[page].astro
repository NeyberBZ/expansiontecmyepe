---
// src/pages/tienda/[page].astro
export async function getStaticPaths({ paginate }: any) {
  const { getCollection, getEntry } = await import("astro:content");
  const allProducts = await getCollection("products");

  const productIndex = await Promise.all(
    allProducts.map(async (p: any) => {
      const brand = p.data.brand
        ? await getEntry("brands", p.data.brand)
        : null;
      const category = p.data.category
        ? await getEntry("categories", p.data.category)
        : null;

      return {
        id: p.id,
        title: p.data.title,
        shortDescription: p.data.shortDescription,
        price: p.data.price,
        salePrice: p.data.salePrice,
        brand: brand?.data.name || "Sin Marca",
        category: category?.data.name || "Sin Categoría",
        locations: p.data.locations?.map((l: any) => l.location) || [],
        images: p.data.images,
        url: `/tienda/producto/${p.id}`,
      };
    }),
  );

  return paginate(productIndex, {
    pageSize: 12,
  });
}

import BaseLayout from "../../layouts/BaseLayout.astro";
import FilterPanel from "../../components/shop/FilterPanel.tsx";
import BreadCrumb from "../../components/ui/BreadCrumb.astro";

const { page } = Astro.props as { page: any };

const brands = [...new Set(page.data.map((p: any) => p.brand))];
const categories = [...new Set(page.data.map((p: any) => p.category))];
const locations = [...new Set(page.data.flatMap((p: any) => p.locations))];
---

<BaseLayout
  title="Tienda - ExpansionTec"
  description="Explora nuestra tienda con una amplia variedad de productos tecnológicos. Encuentra celulares, accesorios y más, disponibles en nuestras sucursales. Compra ahora y disfruta de ofertas exclusivas."
  image="/assets/tienda-banner.jpg"
>
  <BreadCrumb crumbs={[{ label: "Inicio", href: "/" }, { label: "Tienda" }]} />

  <section class="container mx-auto px-4 py-8">
    <div class="mb-6">
      <h1 class="text-3xl font-bold">Tienda</h1>
      <p class="text-gray-600">
        {page.data.length} productos en esta página
      </p>
    </div>

    <FilterPanel
      products={page.data}
      brands={brands}
      categories={categories}
      locations={locations}
    />

    <nav class="mt-10 flex items-center justify-center gap-2">
      {
        page.url.prev && (
          <a
            href={page.url.prev}
            class="px-4 py-2 rounded-lg border hover:bg-gray-100"
          >
            Anterior
          </a>
        )
      }

      <span class="px-4 py-2 text-sm text-gray-600">
        Página {page.currentPage} de {page.lastPage}
      </span>

      {
        page.url.next && (
          <a
            href={page.url.next}
            class="px-4 py-2 rounded-lg border hover:bg-gray-100"
          >
            Siguiente
          </a>
        )
      }
    </nav>
  </section>
</BaseLayout>
