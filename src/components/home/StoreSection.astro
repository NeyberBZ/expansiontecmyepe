---
// src/components/home/StoreSection.astro
import Icon from "../ui/Icon.astro";

interface Props {
  locations: any[];
}

const { locations } = Astro.props;
---

<section class="py-16 bg-gray-50">
  <div class="container mx-auto px-4">
    <div class="text-center mb-10">
      <h2 class="font-satoshi text-4xl font-bold text-gray-900 mb-4 flex items-center justify-center gap-2">
        <Icon id="icon-store" name="store" class="w-8 h-8 text-orange-600" />
        Nuestras Tiendas
      </h2>

      <div class="flex justify-center border-b border-gray-200 inline-flex w-full overflow-x-auto">
        {locations.map((loc, index) => (
          <button
            class={`tab-btn px-6 py-3 font-medium text-sm transition-all border-b-2 whitespace-nowrap flex items-center gap-2 ${index === 0 ? 'border-orange-600 text-orange-600' : 'border-transparent text-gray-500 hover:text-gray-700'}`}
            data-target={`store-${loc.slug}`}
          >
            <Icon id="icon-pin" name="pin" class="w-4 h-4" />
            {loc.data.name}
          </button>
        ))}
      </div>
    </div>

    <div class="max-w-5xl mx-auto">
      {locations.map((loc, index) => (
        <div
          id={`store-${loc.slug}`}
          class={`store-content grid md:grid-cols-2 gap-8 bg-white p-6 rounded-3xl shadow-sm border border-gray-100 ${index === 0 ? 'block' : 'hidden'}`}
        >
          {/* Información y Foto */}
          <div class="space-y-6">
            <h3 class="text-3xl font-bold text-gray-900">{loc.data.name}</h3>

            <div class="aspect-video rounded-2xl overflow-hidden bg-gray-200">
              <img
                src={loc.data.image || "/uploads/store-placeholder.jpg"}
                alt={loc.data.name}
                class="w-full h-full object-cover"
              />
            </div>

            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <Icon id="icon-map" name="map" class="w-5 h-5 text-orange-600 mt-1" />
                <div>
                  <p class="font-bold text-gray-900">Dirección</p>
                  <p class="text-gray-600">{loc.data.address || "Dirección no disponible"}</p>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <Icon id="icon-clock" name="clock" class="w-5 h-5 text-orange-600 mt-1" />
                <div>
                  <p class="font-bold text-gray-900">Horario</p>
                  <p class="text-gray-600">{loc.data.schedule || "Lun - Sáb: 9:00 AM - 8:00 PM"}</p>
                </div>
              </div>
            </div>

            <div class="flex gap-3 pt-4">
              <a href={loc.data.googleMapsUrl} target="_blank" class="flex-1 bg-slate-900 text-white py-3 px-4 rounded-xl font-bold flex items-center justify-center gap-2 hover:bg-slate-800 transition-colors">
                <Icon id="icon-direction" name="direction" class="w-5 h-5" />
                Cómo llegar
              </a>
              <a href={loc.data.wazeUrl} target="_blank" class="flex-1 bg-blue-500 text-white py-3 px-4 rounded-xl font-bold flex items-center justify-center gap-2 hover:bg-blue-600 transition-colors">
                <Icon id="icon-waze" name="waze" class="w-5 h-5" />
                Waze
              </a>
            </div>
          </div>

          {/* Mapa embebido */}
          <div class="h-full min-h-[300px] rounded-2xl overflow-hidden border border-gray-100">
            <iframe
              src={loc.data.mapEmbedUrl}
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const buttons = document.querySelectorAll('.tab-btn');
  const contents = document.querySelectorAll('.store-content');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.getAttribute('data-target');

      if (!target) return;

      // Limpiar estados
      buttons.forEach(b => b.classList.remove('border-orange-600', 'text-orange-600'));
      buttons.forEach(b => b.classList.add('border-transparent', 'text-gray-500'));
      contents.forEach(c => c.classList.add('hidden'));

      // Activar actual
      btn.classList.add('border-orange-600', 'text-orange-600');
      btn.classList.remove('border-transparent', 'text-gray-500');
      document.getElementById(target)?.classList.remove('hidden');
    });
  });
</script>