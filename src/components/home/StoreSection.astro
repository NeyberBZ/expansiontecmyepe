---
// src/components/home/StoreSection.astro
import Icon from "../ui/Icon.astro";

interface Props {
  locations: any[];
}

const { locations } = Astro.props;
---

<section class="py-16 bg-gray-50">
  <div class="container mx-auto px-4">
    <div class="text-center mb-10">
      <h2
        class="font-satoshi text-4xl font-medium text-gray-900 mb-8 flex items-center justify-center gap-2"
      >
        <Icon id="icon-store" name="store" class="w-8 h-8 text-orange-600" />
        Nuestras Tiendas
      </h2>

      <div class="relative">
        <div class="flex gap-4 justify-center overflow-x-auto">
          {
            locations.map((loc, index) => (
              <button
                class={`
                  tab-btn px-6 py-4 font-medium text-base transition-all whitespace-nowrap
                  flex items-center gap-2 border-b-2 relative
                  ${
                    index === 0
                      ? "border-orange-600 text-orange-600"
                      : "border-transparent text-gray-500 hover:text-orange-600 hover:border-orange-600"
                  }
                `}
                data-target={`store-${loc.slug}`}
              >
                <Icon
                  id={`icon-location-${loc.slug}`}
                  name="location"
                  class="w-6 h-6"
                />
                {loc.data.name}
              </button>
            ))
          }
        </div>
      </div>
    </div>

    <div class="max-w-6xl mx-auto">
      {
        locations.map((loc, index) => (
          <div
            id={`store-${loc.slug}`}
            class={`store-content grid md:grid-cols-2 gap-8 bg-white p-6 md:p-8 rounded-3xl shadow-sm border border-gray-100 ${index === 0 ? "grid" : "hidden"}`}
          >
            {/* Información y Foto */}
            <div class="space-y-6">
              <h3 class="text-3xl font-bold text-gray-900">{loc.data.name}</h3>

              <div class="aspect-video rounded-2xl overflow-hidden bg-gray-100 border border-gray-100">
                <img
                  src={loc.data.image || "/uploads/store-placeholder.jpg"}
                  alt={loc.data.name}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>

              <div class="space-y-5">
                <div class="flex items-start gap-3">
                  <div class="bg-orange-50 p-2 rounded-lg">
                    <Icon
                      id="icon-map"
                      name="map"
                      class="w-5 h-5 text-orange-600"
                    />
                  </div>
                  <div>
                    <p class="font-bold text-gray-900 text-sm uppercase tracking-wider">
                      Dirección
                    </p>
                    <p class="text-gray-600 leading-relaxed">
                      {loc.data.address || "Dirección no disponible"}
                    </p>
                  </div>
                </div>

                <div class="flex items-start gap-3">
                  <div class="bg-orange-50 p-2 rounded-lg">
                    <Icon
                      id="icon-clock"
                      name="clock"
                      class="w-5 h-5 text-orange-600"
                    />
                  </div>
                  <div>
                    <p class="font-bold text-gray-900 text-sm uppercase tracking-wider">
                      Horario de atención
                    </p>
                    <p class="text-gray-600 leading-relaxed">
                      {loc.data.schedule || "Lun - Sáb: 9:00 AM - 8:00 PM"}
                    </p>
                  </div>
                </div>
              </div>

              <div class="flex flex-col sm:flex-row gap-3 pt-4">
                <a
                  href={loc.data.googleMapsUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex-1 bg-slate-900 text-white py-4 px-6 rounded-2xl font-bold flex items-center justify-center gap-2 hover:bg-slate-800 transition-all active:scale-95"
                >
                  <Icon
                    id={`icon-direction-${loc.slug}`}
                    name="direction"
                    class="w-5 h-5"
                  />
                  Google Maps
                </a>
                <a
                  href={loc.data.wazeUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex-1 bg-[#33ccff] text-white py-4 px-6 rounded-2xl font-bold flex items-center justify-center gap-2 hover:bg-[#2bb5e0] transition-all active:scale-95"
                >
                  <Icon
                    id="{`icon-waze-${loc.slug}`}"
                    name="waze"
                    class="w-5 h-5 text-white"
                  />
                  Waze
                </a>
              </div>
            </div>

            {/* Mapa embebido */}
            <div class="h-full min-h-[350px] md:min-h-full rounded-2xl overflow-hidden border border-gray-100 shadow-inner">
              <iframe
                src={loc.data.mapEmbedUrl}
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                class="grayscale hover:grayscale-0 transition-all duration-500"
              />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  function setupTabs() {
    const buttons = document.querySelectorAll(".tab-btn");
    const contents = document.querySelectorAll(".store-content");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const targetId = btn.getAttribute("data-target");
        if (!targetId) return;

        // Resetear botones
        buttons.forEach((b) => {
          b.classList.remove("border-orange-600", "text-orange-600");
          b.classList.add("border-transparent", "text-gray-500");
        });

        // Activar botón clickeado
        btn.classList.add("border-orange-600", "text-orange-600");
        btn.classList.remove("border-transparent", "text-gray-500");

        // Resetear contenidos (ocultar todos y mostrar el seleccionado)
        contents.forEach((c) => {
          c.classList.add("hidden");
          c.classList.remove("grid"); // Usamos grid para mantener el layout md:grid-cols-2
        });

        const targetContent = document.getElementById(targetId);
        if (targetContent) {
          targetContent.classList.remove("hidden");
          targetContent.classList.add("grid");
        }
      });
    });
  }

  // Ejecutar en carga inicial
  setupTabs();

  // Ejecutar si usas transiciones de Astro (View Transitions)
  document.addEventListener("astro:after-swap", setupTabs);
</script>
