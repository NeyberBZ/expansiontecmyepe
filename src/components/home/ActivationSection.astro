---
import Icon from "../../components/ui/Icon.astro";

interface Props {
  activations: any[];
}

const { activations } = Astro.props;
const nowTime = Date.now();

// Pre-procesa todo aquí, fuera del template
const processedActivations = activations.map((a) => {
  const startObj = new Date(a.data.startDate);
  const endObj = new Date(a.data.endDate);
  const isRunning =
    nowTime >= startObj.getTime() && nowTime <= endObj.getTime();

  return {
    ...a,
    _badge: isRunning ? "Activa" : "Próxima",
    _variant: isRunning ? "success" : "primary",
    _start: startObj.toLocaleDateString("es-PE", {
      day: "2-digit",
      month: "short",
    }),
    _end: endObj.toLocaleDateString("es-PE", {
      day: "2-digit",
      month: "short",
      year: "numeric",
    }),
    _location:
      a.locationNames?.length > 0
        ? a.locationNames.join(" | ")
        : "Sedes múltiples",
    _url: `/activaciones/${a.id || a.slug}`,
    _banner: a.data.banner || "/uploads/placeholder-activation.jpg",
  };
});
---

{
  processedActivations.length > 0 ? (
    <section class="py-12 sm:py-16">
      <div class="container mx-auto">
        <div class="flex items-center justify-between mb-10 flex-wrap gap-4">
          <h2 class="font-satoshi text-4xl font-medium text-gray-900">
            Activaciones
          </h2>
          {/* <a
            href="/activaciones"
            class="text-sm font-medium text-orange-600 hover:underline tracking-wider"
          >
            Ver todas las activaciones →
          </a> */}
          <a
            href="/activaciones"
            class="inline-flex items-center gap-2 text-white hover:text-white font-semibold text-sm tracking-wider bg-orange-600 hover:bg-orange-400 px-4 py-2 rounded-xl transition-colors shadow-md hover:shadow-lg"
          >
            <span>Ver todas las activaciones</span>
            <Icon
              id="icon-arrow-right-square"
              name="arrow-right-square"
              class="w-4 h-4"
            />
          </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
          {processedActivations.map((a) => (
            <div class="col-span-1 sm:col-span-2 lg:col-span-2 xl:col-span-2">
              <article class="group relative bg-gradient-to-br from-[#f59e0b] via-[#ea580c] to-[#b91c1c] rounded-3xl hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col h-full max-h-64 min-h-64">
                <a href={a._url} class="h-full w-full flex flex-col">
                  <div class="absolute top-4 left-4 w-1/2 z-10 flex flex-col gap-2">
                    <h3 class="font-bold text-2xl text-white group-hover:text-orange-100 transition-colors line-clamp-2">
                      {a.data.title}
                    </h3>
                    <div class="flex flex-wrap gap-2">
                      <span class="w-fit px-3 py-1 bg-white/20 backdrop-blur-md text-white text-xs font-bold rounded-lg border border-white/30">
                        {a._badge}
                      </span>
                    </div>
                  </div>
                  <div class="absolute top-1/2 -translate-y-1/2 right-5 overflow-hidden">
                    <img
                      src={a._banner}
                      alt={a.data.title}
                      class="w-full h-44 object-scale-down rounded-2xl transform border-4 border-orange-100/20"
                      loading="lazy"
                    />
                  </div>
                  <div class="absolute bottom-4 left-4 right-4 z-10p-5 flex-1 flex flex-col">
                    <div class="flex items-baseline gap-2">
                      <span class="text-lg font-bold text-white group-hover:text-orange-100">
                        {a._start} al {a._end}
                      </span>
                    </div>
                    <div class="text-base font-medium text-white">
                      {a._location}
                    </div>
                  </div>
                </a>
                {/* <a href={a._url} class="group block">
                <div class="relative aspect-[16/9] overflow-hidden">
                  <img
                    src={a._banner}
                    alt={a.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                  />
                  <div class="absolute top-4 right-4">
                    <Badge variant={a._variant}>{a._badge}</Badge>
                  </div>
                </div>

                <div class="p-6 flex flex-col flex-1">
                  <h3 class="text-xl font-bold text-gray-900 mb-4 group-hover:text-orange-600 transition-colors line-clamp-2">
                    {a.data.title}
                  </h3>
                  <div class="mt-auto space-y-3">
                    <div class="flex items-center gap-2 text-sm text-gray-600 font-medium">
                      <span class="text-lg">📍</span>
                      <span class="line-clamp-1">{a._location}</span>
                    </div>
                    <div class="flex items-center gap-2 text-[11px] font-bold uppercase tracking-widest text-gray-400 border-t border-gray-200 pt-4">
                      <span>{a._start}</span>
                      <span>—</span>
                      <span>{a._end}</span>
                    </div>
                  </div>
                </div>
              </a> */}
              </article>
            </div>
          ))}
        </div>
      </div>
    </section>
  ) : null
}
