---
// src/components/ui/BreadCrumb.astro
import Icon from './Icon.astro';
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  crumbs: Crumb[];
}
const { crumbs } = Astro.props;
---

<nav
  aria-label="Breadcrumb"
  class="text-base text-gray-600 mb-4 tracking-wider"
>
  <ol class="flex flex-wrap items-center gap-1">
    <li>
      <Icon id="icon-home" name="home" class="w-6 h-6 text-gray-600" />
    </li>
    {
      crumbs.map((crumb, i) => (
        <li class="flex items-center gap-1">
          {i > 0 && (
            <span aria-hidden="true" class="text-[var(--color-text-faint)]">
              <Icon id="icon-right" name="right" class="h-4 w-4" />
            </span>
          )}
          {crumb.href && i < crumbs.length - 1 ? (
            <a
              href={crumb.href}
              class="hover:text-orange-600 transition-colors"
            >
              {crumb.label}
            </a>
          ) : (
            <span
              class="text-orange-600 font-medium"
              aria-current={i === crumbs.length - 1 ? "page" : undefined}
            >
              {crumb.label}
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
