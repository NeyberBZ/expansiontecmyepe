---
// src/components/ui/BreadCrumb.astro
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  crumbs: Crumb[];
}
const { crumbs } = Astro.props;
---

<nav
  aria-label="Breadcrumb"
  class="text-xs text-[var(--color-text-muted)] mb-4"
>
  <ol class="flex flex-wrap items-center gap-1">
    {
      crumbs.map((crumb, i) => (
        <li class="flex items-center gap-1">
          {i > 0 && (
            <span aria-hidden="true" class="text-[var(--color-text-faint)]">
              /
            </span>
          )}
          {crumb.href && i < crumbs.length - 1 ? (
            <a
              href={crumb.href}
              class="hover:text-[var(--color-primary)] transition-colors"
            >
              {crumb.label}
            </a>
          ) : (
            <span
              class="text-[var(--color-text)]"
              aria-current={i === crumbs.length - 1 ? "page" : undefined}
            >
              {crumb.label}
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
