---
// src/components/ui/Badge.astro
interface Props {
  variant?: "default" | "success" | "warning" | "error" | "primary";
  class?: string;
}
const { variant = "default", class: className = "" } = Astro.props;

const variants = {
  default:
    "bg-red-600 text-white dark:bg-transparent dark:border dark:border-red-600 dark:text-red-600",
  primary:
    "bg-teal-500 text-white dark:bg-transparent dark:border dark:border-teal-600 dark:text-teal-600",
  success:
    "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-400",
  warning:
    "bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-400",
  error: "bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400",
};
---

<span
  class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${variants[variant]} ${className}`}
>
  <slot />
</span>
