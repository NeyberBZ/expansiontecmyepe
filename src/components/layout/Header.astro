            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={s.label}
            class="w-8 h-8 flex items-center justify-center px-1.5 text-gray-500 hover:text-orange-600 transition-colors duration-200 dark:text-gray-400 dark:hover:text-orange-600 dark:hover:bg-red-50"
          >
            <Fragment set:html={s.icon} />
          </a>
        ))
      }
    </div>
  </nav>
</header>

<script is:inline>
  (function () {
    // ── Theme ──────────────────────────────────────────────
    const root = document.documentElement;
    const prefersDark = window.matchMedia(
      "(prefers-color-scheme: dark)",
    ).matches;
    let theme = prefersDark ? "dark" : "light";
    root.setAttribute("data-theme", theme);

    function updateIcons() {
      const sun = document.getElementById("icon-sun");
      const moon = document.getElementById("icon-moon");
      if (!sun || !moon) return;
      sun.style.display = theme === "dark" ? "block" : "none";
      moon.style.display = theme === "light" ? "block" : "none";
    }
    updateIcons();

    document
      .querySelector("[data-theme-toggle]")
      ?.addEventListener("click", () => {
        theme = theme === "dark" ? "light" : "dark";
        root.setAttribute("data-theme", theme);
        updateIcons();
      });

    // ── Responsive ────────────────────────────────────────
    const navDesktop = document.getElementById("nav-desktop");
    const socialLinks = document.getElementById("social-links");
    const mobileBtn = document.getElementById("mobile-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");
    const hamburgerIcon = document.getElementById("hamburger-icon");
    const closeIcon = document.getElementById("close-icon");

    function handleResize() {
      const isDesktop = window.innerWidth >= 768;
      if (navDesktop) navDesktop.style.display = isDesktop ? "flex" : "none";
      if (socialLinks) socialLinks.style.display = isDesktop ? "flex" : "none";
      if (mobileBtn) mobileBtn.style.display = isDesktop ? "none" : "flex";
      if (isDesktop && mobileMenu) {
        mobileMenu.style.display = "none";
        if (hamburgerIcon) hamburgerIcon.style.display = "block";
        if (closeIcon) closeIcon.style.display = "none";
      }
    }
    handleResize();
    window.addEventListener("resize", handleResize);

    // ── Mobile menu toggle ────────────────────────────────
    let menuOpen = false;
    mobileBtn?.addEventListener("click", () => {
      menuOpen = !menuOpen;
      if (mobileMenu) mobileMenu.style.display = menuOpen ? "block" : "none";
      if (hamburgerIcon)
        hamburgerIcon.style.display = menuOpen ? "none" : "block";
      if (closeIcon) closeIcon.style.display = menuOpen ? "block" : "none";
      mobileBtn.setAttribute("aria-expanded", String(menuOpen));
    });

    // Cierra el menú al hacer click en un link
    mobileMenu?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        menuOpen = false;
        if (mobileMenu) mobileMenu.style.display = "none";
        if (hamburgerIcon) hamburgerIcon.style.display = "block";
        if (closeIcon) closeIcon.style.display = "none";
        mobileBtn?.setAttribute("aria-expanded", "false");
      });
    });
  })();
</script>
