---
// src/components/layout/Header.astro
import Icon from "../../components/ui/Icon.astro";
import CartIcon from "../../components/shop/CartIcon.tsx";
const navLinks = [
  { href: "/tienda", label: "Tienda" },
  { href: "/sucursales", label: "Sucursales" },
  { href: "/activaciones", label: "Activaciones" },
  { href: "/contacto", label: "Contáctanos" },
];
const currentPath = Astro.url.pathname;
---

<header
  class="fixed w-full top-0 left-0 right-0 z-50 transition-all duration-300 bg-white/80 dark:bg-black/80 shadow-lg backdrop-blur-sm"
>
  <div class="w-full mx-auto px-4">
    <div class="flex items-center justify-between h-14">
      <!-- LOGO -->
      <a
        href="/"
        class="flex items-center gap-2 text-lg font-bold shrink-0"
        aria-label="Expansion - Inicio"
      >
        <!-- Ícono circular rojo -->
        <img
          src="/logo.svg"
          alt="Expansion Logo"
          class="h-10 w-auto transition-transform group-hover:scale-105"
          width="120"
          height="40"
        />
      </a>

      <!-- NAV DESKTOP -->
      <nav
        id="nav-desktop"
        class="hidden items-center gap-1"
        aria-label="Navegación principal"
      >
        {
          navLinks.map(({ href, label }) => {
            const isActive =
              href === "/" ? currentPath === "/" : currentPath.startsWith(href);
            return (
              <a
                href={href}
                class="px-3.5 py-1.5 font-medium text-base tracking-wider text-gray-700 hover:text-orange-600 dark:text-gray-200 dark:hover:text-red-600"
                style={`
                transition: all 180ms ease;
                ${isActive ? "color: #ea580c" : "color: #374151;"}
              `}
              >
                {label}
              </a>
            );
          })
        }
      </nav>

      <!-- ACCIONES DERECHA -->
      <div class="flex items-center gap-2 shrink-0">
        <!-- Redes sociales — solo desktop -->
        <div id="social-links" class="hidden items-center gap-1">
          {
            [
              {
                href: "https://facebook.com",
                label: "Facebook",
                icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" /></svg>`,
              },
              {
