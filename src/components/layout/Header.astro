              },
            ].map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={s.label}
                class="w-8 h-8 flex items-center justify-center px-1.5 text-gray-500 hover:text-orange-600 transition-colors duration-200 dark:text-gray-400 dark:hover:text-orange-600 dark:hover:bg-red-50"
              >
                <Fragment set:html={s.icon} />
              </a>
            ))
          }

          <!-- Separador -->
          <div
            style="width:1px;height:20px;background:var(--color-border);margin:0 4px;"
          >
          </div>
        </div>

        <!-- Búsqueda -->
        <button
          id="search-btn"
          aria-label="Buscar"
          class="w-8 h-8 flex items-center justify-center rounded-full text-gray-500 hover:text-orange-600 transition-colors duration-200 dark:text-gray-400 dark:hover:text-orange-600"
        >
          <Icon id="icon-search" name="search" class="w-5 h-5" />
        </button>

        <CartIcon client:load />

        <!-- Dark/Light toggle -->
        <button
          data-theme-toggle
          aria-label="Cambiar tema"
          class="w-8 h-8 flex items-center justify-center rounded-full text-gray-500 hover:text-orange-600 transition-colors duration-200 dark:text-gray-400 dark:hover:text-orange-600"
        >
          <Icon
            id="icon-sun"
            name="sun"
            class="w-6 h-6 text-gray-500 hover:text-orange-600 transition-colors duration-200 dark:text-gray-400 dark:hover:text-orange-600"
          />
          <Icon
            id="icon-moon"
            name="moon"
            class="w-5 h-5 text-gray-500 hover:text-orange-600 transition-colors duration-200 dark:text-gray-400 dark:hover:text-orange-600"
          />
        </button>

        <!-- Hamburguesa mobile -->
        <button
          id="mobile-menu-btn"
          aria-label="Abrir menú"
          aria-expanded="false"
          style="width:34px;height:34px;display:flex;align-items:center;justify-content:center;border-radius:6px;color:var(--color-text-muted);background:none;border:none;cursor:pointer;"
        >
          <Icon name="hamburger" id="hamburger-icon" class="w-5 h-5" />
          <Icon name="close" id="close-icon" class="w-5 h-5 hidden" />
        </button>
      </div>
    </div>
  </div>

  <!-- MOBILE MENU -->
  <nav
    id="mobile-menu"
    style="display:none;background:var(--color-surface);border-top:1px solid var(--color-border);padding:1rem 1.25rem;"
    aria-label="Menú móvil"
  >
    <!-- Links nav -->
    <div style="display:flex;flex-direction:column;gap:4px;margin-bottom:1rem;">
      {
        navLinks.map(({ href, label }) => {
          const isActive =
            href === "/" ? currentPath === "/" : currentPath.startsWith(href);
          return (
            <a
              href={href}
              class="px-3.5 py-1.5 font-medium text-base tracking-wider text-gray-700 hover:text-orange-600 dark:text-gray-200 dark:hover:text-red-600"
              style={`
              transition: all 180ms ease;
              ${isActive ? "color: #cc2200;" : "color: #374151;"}
            `}
            >
              {label}
            </a>
          );
        })
      }
    </div>

    <!-- Redes sociales mobile -->
    <div
      style="display:flex;gap:12px;padding-top:1rem;border-top:1px solid var(--color-divider);"
    >
